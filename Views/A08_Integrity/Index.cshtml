@model OWASPDemo.Models.DeserializeViewModel
@{
    ViewData["Title"] = "A08 — Software Integrity Failures";
}

<h4 class="fw-bold">A08 — Software and Data Integrity Failures</h4>
<p class="text-muted">Insecure deserialization, unverified updates, and untrusted data pipelines.</p>

<div class="row g-3 mb-3">
    <div class="col-md-12">
        <div class="alert alert-danger py-2 mb-0 small">
            <strong>⚡ Attack:</strong> Craft JSON with <code>"command": "rm -rf /"</code> — insecure deserializer executes it
        </div>
    </div>
</div>

<div class="mb-2 small text-muted">
    <strong>Vulnerable payload:</strong> <code>{"command": "rm -rf /tmp", "name": "exploit"}</code>
</div>

<div class="row g-3">
    <!-- VULNERABLE -->
    <div class="col-lg-12">
        <div class="demo-container card-vulnerable">
            <h6 class="text-danger fw-bold">🔴 VULNERABLE — Dynamic Deserialization</h6>
            <div class="attack-tip mb-3 small">
                <strong>⚡ Try:</strong> <code>@("{\"command\": \"rm -rf /tmp\", \"name\": \"exploit\"}")</code>
            </div>
            <form method="post" asp-action="VulnerableDeserialize">
                <textarea name="JsonInput" rows="3" class="form-control form-control-sm mb-2" placeholder='{"name": "test", "command": "rm -rf /"}'>@(Model.IsVulnerable ? Model.JsonInput : "")</textarea>
                <button class="btn btn-danger btn-sm">Deserialize (Vulnerable)</button>
            </form>
            @if (Model.IsVulnerable)
            {
                @if (Model.Error != null)
                {
                    <div class="alert alert-warning mt-2 small">@Model.Error</div>
                }
                else if (Model.Output != null)
                {
                    <div class="code-block mt-2 small"><pre>@Model.Output</pre></div>
                }
            }
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-md-12">
        <div class="code-block">
<pre>// VULNERABLE: Newtonsoft TypeNameHandling.All
var settings = new JsonSerializerSettings {
    TypeNameHandling = TypeNameHandling.All
};
// Attacker sends: {"$type":"System.Diagnostics.Process, ..."}
// → Remote Code Execution!</pre>
        </div>
    </div>
</div>

<div class="mt-3 p-3 bg-light border rounded small">
    <strong>Real-world example:</strong> The <strong>Uber breach (2022)</strong> — attacker sent a push notification to an Uber employee
    who accepted it (MFA fatigue). Combined with insecure session handling, this led to full admin access.
    Separately, the 2021 Log4Shell CVE (Log4j) used insecure JNDI lookup deserialization for RCE affecting millions of systems.
</div>
