@{
    ViewData["Title"] = "Error Demo";
    bool isVulnerable = ViewBag.IsVulnerable ?? true;
    string detail = ViewBag.ErrorDetail ?? "";
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back</a>

@if (isVulnerable)
{
    <div class="demo-container card-vulnerable">
        <h6 class="text-danger fw-bold">🔴 VULNERABLE — Full Exception Leaked to Browser</h6>
        <div class="alert alert-danger">
            <strong>HTTP 500 Internal Server Error</strong>
            <pre class="mt-2 small" style="max-height:300px;overflow:auto">@detail</pre>
        </div>
        <p class="small text-muted">
            An attacker now knows: internal DB server name, credentials format, .NET version, file paths, and framework internals.
        </p>
    </div>
}
else
{
    <div class="demo-container card-secure">
        <h6 class="text-success fw-bold">🟢 SECURE — Generic Error Message</h6>
        <div class="alert alert-warning">
            <strong>Something went wrong.</strong><br />
            @detail
        </div>
        <p class="small text-success">
            ✅ Full exception details were written to the internal application log — not exposed to the user.
        </p>
    </div>
}
