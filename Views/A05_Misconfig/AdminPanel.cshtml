@{
    ViewData["Title"] = "Admin Panel";
    var users = ViewBag.Users as List<OWASPDemo.Models.User>;
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back</a>

<div class="demo-container card-vulnerable">
    <h6 class="text-danger fw-bold">🔴 VULNERABLE — No Auth Admin Panel</h6>
    <div class="alert alert-danger small">
        ⚠️ This admin panel is accessible without any authentication. Any user can view all accounts.
    </div>
    @if (users != null)
    {
        <table class="table table-sm table-danger">
            <thead><tr><th>ID</th><th>Username</th><th>Email</th><th>Role</th><th>Balance</th><th>CC</th></tr></thead>
            <tbody>
                @foreach (var u in users)
                {
                    <tr>
                        <td>@u.Id</td><td>@u.Username</td><td>@u.Email</td>
                        <td><span class="badge @(u.Role=="admin"?"bg-danger":"bg-secondary")">@u.Role</span></td>
                        <td>@u.AccountBalance.ToString("C")</td>
                        <td>@u.CreditCard</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
