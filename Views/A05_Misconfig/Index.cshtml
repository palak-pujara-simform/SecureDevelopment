@{
    ViewData["Title"] = "A05 — Security Misconfiguration";
}

<h4 class="fw-bold">A05 — Security Misconfiguration</h4>
<p class="text-muted">Insecure defaults, unnecessary features, verbose errors — the most common OWASP issue.</p>

<div class="row g-3 mb-4">
    <!-- Error Messages -->
    <div class="col-lg-12">
        <div class="demo-container card-vulnerable">
            <h6 class="text-danger fw-bold">🔴 VULNERABLE — Detailed Error Messages</h6>
            <p class="small text-muted">Exception details leaked to the browser reveal internal DB credentials, file paths, and architecture.</p>
            <a asp-action="VulnerableError" class="btn btn-danger btn-sm">Trigger Error (Verbose)</a>
            <div class="code-block mt-3">
<pre>// VULNERABLE
catch (Exception ex)
{
    return Content(ex.ToString());
    // Exposes: connection strings, stack trace,
    // internal server paths, library versions
}</pre>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Admin Panel Access -->
    <div class="col-lg-12">
        <div class="demo-container card-vulnerable">
            <h6 class="text-danger fw-bold">🔴 VULNERABLE — Admin Panel Without Auth</h6>
            <p class="small text-muted">Admin endpoint accessible without any authentication check.</p>
            <a asp-action="VulnerableAdmin" class="btn btn-danger btn-sm">Access Admin Panel (No Auth)</a>
        </div>
    </div>
</div>
