@model OWASPDemo.Models.LoggingViewModel
@{
    ViewData["Title"] = "A09 — Logging Failures";
}

<h4 class="fw-bold">A09 — Security Logging and Monitoring Failures</h4>
<p class="text-muted">Without proper audit trails, breaches go undetected for months. PII in logs creates additional exposure.</p>

<div class="row g-3 mb-3">
    <div class="col-md-12">
        <div class="alert alert-danger py-2 mb-0 small">
            <strong>⚡ Problems:</strong> No audit trail for logins, passwords logged in plaintext, no brute-force detection
        </div>
    </div>
</div>

<div class="mb-2 small text-muted">
    Test users: <code>alice / password123</code> &nbsp;|&nbsp; <code>bob / bobpass</code> &nbsp;|&nbsp;
    <a asp-action="ClearLogs" class="text-decoration-none text-danger">Clear All Logs</a>
</div>

<div class="row g-3">
    <!-- VULNERABLE -->
    <div class="col-lg-12">
        <div class="demo-container card-vulnerable">
            <h6 class="text-danger fw-bold">🔴 VULNERABLE — Password in Logs, No Audit Trail</h6>
            <div class="attack-tip mb-3 small">
                <strong>⚡ Try:</strong> Login with correct then wrong credentials.<br />
                Notice: the <strong>password and SSN are logged</strong>! No failed-login tracking.
            </div>
            <form method="post" asp-action="VulnerableLogin">
                <div class="mb-1">
                    <input type="text" name="Username" value="@(Model.IsVulnerable ? Model.Username : "")" placeholder="alice" class="form-control form-control-sm" />
                </div>
                <div class="mb-2">
                    <input type="password" name="Password" placeholder="password123" class="form-control form-control-sm" />
                </div>
                <button class="btn btn-danger btn-sm">Login (Vulnerable Logging)</button>
            </form>
            @if (Model.IsVulnerable && Model.LogOutput != null)
            {
                <div class="code-block mt-2 small"><pre>LOG OUTPUT:
@Model.LogOutput</pre></div>
                <small class="@(Model.Success ? "text-warning" : "text-muted")">@Model.Message</small>
            }
        </div>
    </div>
</div>
