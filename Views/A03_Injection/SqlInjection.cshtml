@model OWASPDemo.Models.SqlSearchViewModel
@{
    ViewData["Title"] = "SQL Injection Demo";
}

<div class="d-flex gap-2 mb-3 align-items-center">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back</a>
    <h5 class="fw-bold mb-0">SQL Injection — Product Search</h5>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="alert alert-danger py-2 mb-0 small">
            <strong>⚡ Attack payload:</strong> <code>' OR '1'='1</code> — returns ALL rows<br />
            Also try: <code>%' UNION SELECT Id,Username,PasswordPlain,AccountBalance,SSN FROM Users--</code>
        </div>
    </div>
    <div class="col-md-6">
        <div class="alert alert-success py-2 mb-0 small">
            <strong>🛡️ Defense:</strong> Parameterized queries — user input never interpreted as SQL syntax
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- VULNERABLE -->
    <div class="col-lg-6">
        <div class="demo-container card-vulnerable">
            <h6 class="text-danger fw-bold">🔴 VULNERABLE — String Concatenation</h6>
            <form method="post" asp-action="SqlVulnerable">
                <div class="d-flex gap-2">
                    <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="Search products..." class="form-control form-control-sm" />
                    <button class="btn btn-danger btn-sm">Search</button>
                </div>
            </form>
            @if (Model.IsVulnerable && Model.SqlQuery != null)
            {
                <div class="code-block mt-2 small">
                    <span class="text-warning">Executed SQL:</span><br />@Model.SqlQuery
                </div>
            }
        </div>
    </div>

    <!-- SECURE -->
    <div class="col-lg-6">
        <div class="demo-container card-secure">
            <h6 class="text-success fw-bold">🟢 SECURE — Parameterized Query</h6>
            <form method="post" asp-action="SqlSecure">
                <div class="d-flex gap-2">
                    <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="Search products..." class="form-control form-control-sm" />
                    <button class="btn btn-success btn-sm">Search</button>
                </div>
            </form>
            @if (!Model.IsVulnerable && Model.SqlQuery != null)
            {
                <div class="code-block mt-2 small">
                    <span class="text-success">Executed SQL:</span><br />@Model.SqlQuery
                </div>
            }
        </div>
    </div>
</div>

@if (Model.Error != null)
{
    <div class="alert alert-warning mt-3 small"><strong>DB Error:</strong> @Model.Error</div>
}

@if (Model.Results != null)
{
    <div class="mt-3">
        <h6 class="fw-bold @(Model.IsVulnerable ? "text-danger" : "text-success")">
            @(Model.IsVulnerable ? "🔴 VULNERABLE" : "🟢 SECURE") — @Model.Results.Count result(s)
        </h6>
        @if (Model.IsVulnerable && Model.Results.Count > 5)
        {
            <div class="alert alert-danger small">⚠️ Injection returned @Model.Results.Count rows — attacker dumped entire table!</div>
        }
        <table class="table table-sm @(Model.IsVulnerable && Model.Results.Count > 5 ? "table-danger" : "")">
            <thead><tr><th>ID</th><th>Name</th><th>Description</th><th>Price</th><th>Category</th></tr></thead>
            <tbody>
                @foreach (var p in Model.Results)
                {
                    <tr><td>@p.Id</td><td>@p.Name</td><td>@p.Description</td><td>@p.Price.ToString("C")</td><td>@p.Category</td></tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="row g-3 mt-1">
    <div class="col-md-6">
        <div class="code-block">
<pre>// VULNERABLE
var sql = "SELECT * FROM Products WHERE Name LIKE '%"
          + searchTerm + "%'";
// Input: ' OR '1'='1
// Result: all rows returned!</pre>
        </div>
    </div>
    <div class="col-md-6">
        <div class="code-block">
<pre>// SECURE
cmd.CommandText = "SELECT * FROM Products
    WHERE Name LIKE @@term";
cmd.Parameters.AddWithValue("@@term",
    "%" + searchTerm + "%");
// Input treated as literal string, not SQL</pre>
        </div>
    </div>
</div>
