@{
    ViewData["Title"] = "Dashboard";
}

<h4 class="fw-bold mb-1">OWASP Top 10 — Live Demo</h4>
<p class="text-muted mb-4">Each card links to a live, interactive demonstration of the <span class="text-danger fw-semibold">vulnerable</span> code path and how it can be exploited.</p>

<div class="row g-3">
    @{
        var demos = new[]
        {
            new { Id="A01", Title="Broken Access Control", Icon="🔓", Severity="Critical",
                Color="danger", Ctrl="A01_BrokenAccess",
                Desc="Access another user's account by changing a URL parameter (IDOR).",
                Attack="?userId=2", Fix="Ownership check + authorization" },
            new { Id="A02", Title="Cryptographic Failures", Icon="🔑", Severity="Critical",
                Color="danger", Ctrl="A02_Cryptographic",
                Desc="Password stored as MD5 hash vs BCrypt. Hardcoded secrets in config.",
                Attack="MD5 rainbow table", Fix="BCrypt + secrets management" },
            new { Id="A03", Title="Injection", Icon="💉", Severity="Critical",
                Color="danger", Ctrl="A03_Injection",
                Desc="SQL Injection, XSS, and Command Injection — live interactive demos.",
                Attack="' OR '1'='1; <script>alert()</script>", Fix="Parameterized queries + encoding" },
            new { Id="A04", Title="Insecure Design", Icon="🏗️", Severity="High",
                Color="warning", Ctrl="A04_InsecureDesign",
                Desc="Password reset without rate limiting — enables account takeover via spam.",
                Attack="Flood reset endpoint", Fix="Rate limiting + short-lived tokens" },
            new { Id="A05", Title="Security Misconfiguration", Icon="⚙️", Severity="High",
                Color="warning", Ctrl="A05_Misconfig",
                Desc="Detailed error messages leaking stack traces and internal paths.",
                Attack="Trigger exception, read response", Fix="Generic errors + internal logging" },
            new { Id="A06", Title="Vulnerable Components", Icon="📦", Severity="High",
                Color="warning", Ctrl="A06_Components",
                Desc="Supply-chain risk from outdated NuGet packages with known CVEs.",
                Attack="SolarWinds supply chain", Fix="dotnet list package --vulnerable" },
            new { Id="A07", Title="Auth & Session Failures", Icon="🔐", Severity="Critical",
                Color="danger", Ctrl="A07_Auth",
                Desc="No account lockout + plaintext password comparison + session fixation.",
                Attack="Brute force 5 attempts", Fix="BCrypt + lockout + session regeneration" },
            new { Id="A08", Title="Software Integrity Failures", Icon="🧩", Severity="High",
                Color="warning", Ctrl="A08_Integrity",
                Desc="Insecure deserialization — crafted JSON can trigger unintended execution.",
                Attack="{\"command\":\"rm -rf /\"}", Fix="Deserialize into known type only" },
            new { Id="A09", Title="Logging & Monitoring Failures", Icon="📋", Severity="Medium",
                Color="secondary", Ctrl="A09_Logging",
                Desc="Passwords and PII written to logs. No audit trail for failed logins.",
                Attack="Brute force undetected", Fix="Structured audit logs, never log secrets" },
            new { Id="A10", Title="Server-Side Request Forgery", Icon="🌐", Severity="Medium",
                Color="secondary", Ctrl="A10_SSRF",
                Desc="Server fetches any URL supplied by user — can reach internal services.",
                Attack="http://169.254.169.254/meta-data/", Fix="Allow-list + HTTPS only" },
        };
    }

    @foreach (var d in demos)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header d-flex justify-content-between align-items-center bg-@d.Color @(d.Color == "warning" ? "text-dark" : "text-white") py-2">
                    <span class="fw-bold">@d.Icon @d.Id — @d.Title</span>
                    <span class="badge bg-white text-@d.Color">@d.Severity</span>
                </div>
                <div class="card-body">
                    <p class="card-text small">@d.Desc</p>
                    <div class="d-flex flex-wrap gap-1">
                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">⚡ @d.Attack</span>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3">
                    <a asp-controller="@d.Ctrl" asp-action="Index" class="btn btn-sm btn-outline-primary w-100">
                        Open Demo →
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-4 p-3 bg-warning-subtle border border-warning rounded small">
    <strong>⚠️ Educational Use Only:</strong> All demos run against an isolated local SQLite database.
    Never use vulnerable patterns in production code.
    Seed data: <code>alice / password123</code>, <code>bob / bobpass</code>, <code>admin / admin123</code>
</div>
