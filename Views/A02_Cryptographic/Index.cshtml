@model OWASPDemo.Models.CryptoViewModel
@{
    ViewData["Title"] = "A02 — Cryptographic Failures";
}

<h4 class="fw-bold">A02 — Cryptographic Failures</h4>
<p class="text-muted">Weak or missing encryption of sensitive data at rest and in transit.</p>

<div class="row g-3 mb-3">
    <div class="col-md-12">
        <div class="alert alert-danger py-2 mb-0"><strong>Attack:</strong> MD5/SHA1 hashes cracked via rainbow tables in seconds</div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- VULNERABLE -->
    <div class="col-lg-12">
        <div class="demo-container card-vulnerable">
            <h6 class="text-danger fw-bold">🔴 VULNERABLE — MD5 Password Hash</h6>
            <div class="attack-tip mb-3 small">
                <strong>⚡ Try:</strong> Hash "password123" — then Google the MD5 hash. It's in every rainbow table.
            </div>
            <form method="post" asp-action="VulnerableHash">
                <div class="d-flex gap-2">
                    <input type="text" name="Password" value="@Model.Password" placeholder="Enter password" class="form-control form-control-sm" />
                    <button class="btn btn-danger btn-sm">Hash (MD5)</button>
                </div>
            </form>
            @if (Model.IsVulnerable && Model.Hash != null)
            {
                <div class="alert alert-warning mt-3 small">
                    <strong>Algorithm:</strong> @Model.Algorithm<br />
                    <strong>Hash:</strong> <code>@Model.Hash</code><br />
                    <strong>⚠️ @Model.Message</strong>
                </div>
            }
            <div class="code-block mt-3">
<pre>// VULNERABLE
using var md5 = MD5.Create();
var hash = md5.ComputeHash(
    Encoding.UTF8.GetBytes(password));
// No salt, deterministic, broken algorithm</pre>
            </div>
        </div>
    </div>
</div>

<!-- Hardcoded Secrets Demo -->
<div class="demo-container border border-danger">
    <h6 class="text-danger fw-bold">🔴 Hardcoded Secrets in Config (Sensitive Data Exposure)</h6>
    <p class="small text-muted">appsettings.json contains secrets that get committed to source control — a very common mistake.</p>
    <a asp-action="ShowSecrets" class="btn btn-danger btn-sm">Show Exposed Secrets →</a>
    <div class="code-block mt-3">
<pre>// appsettings.json — NEVER store secrets here!
"AppSettings": {
  "SecretKey": "HARDCODED_SECRET_KEY_12345",
  "AdminPassword": "admin123",
  "ApiToken": "eyJhbGciOiJIUzI1NiJ9..."
}</pre>
    </div>
</div>
