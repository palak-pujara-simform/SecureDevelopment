@{
    ViewData["Title"] = "Exposed Secrets";
    var secrets = ViewBag.Secrets as Dictionary<string, string?>;
    var users = ViewBag.Users as List<OWASPDemo.Models.User>;
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back</a>
<h5 class="text-danger fw-bold">⚠️ Sensitive Data Exposed via Config + Database</h5>

<div class="row g-3">
    <div class="col-md-6">
        <div class="demo-container card-vulnerable">
            <h6 class="text-danger fw-bold">Hardcoded Secrets in appsettings.json</h6>
            <table class="table table-sm table-danger">
                @if (secrets != null)
                {
                    @foreach (var kv in secrets)
                    {
                        <tr><th>@kv.Key</th><td><code>@kv.Value</code></td></tr>
                    }
                }
            </table>
            <p class="small text-muted mt-2">These would be committed to your Git repo and visible to anyone with repo access.</p>
        </div>
    </div>
    <div class="col-md-6">
        <div class="demo-container card-vulnerable">
            <h6 class="text-danger fw-bold">Passwords Stored in Plaintext (DB)</h6>
            <table class="table table-sm">
                <thead><tr><th>User</th><th>Plaintext Password</th><th>SSN</th><th>Credit Card</th></tr></thead>
                <tbody>
                    @if (users != null)
                    {
                        @foreach (var u in users)
                        {
                            <tr class="table-danger">
                                <td>@u.Username</td>
                                <td><code>@u.PasswordPlain</code></td>
                                <td><code>@u.SSN</code></td>
                                <td><code>@u.CreditCard</code></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
